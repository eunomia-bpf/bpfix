{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bpfix.dev/schema/diagnostic-v2.json",
  "title": "BPFix Diagnostic v2",
  "description": "Structured JSON emitted by the Rust bpfix CLI for eBPF verifier-log diagnostics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagnostic_version",
    "error_id",
    "failure_class",
    "confidence",
    "diagnostic_kind",
    "help_safety",
    "span_confidence",
    "message",
    "required_proof",
    "source_span",
    "related_spans",
    "evidence",
    "help",
    "metadata"
  ],
  "properties": {
    "diagnostic_version": {
      "const": "bpfix.diagnostic/v2"
    },
    "error_id": {
      "type": "string",
      "pattern": "^BPFIX-E[0-9]{3}$"
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "source_bug",
        "lowering_artifact",
        "environment_or_configuration",
        "verifier_false_positive",
        "verifier_limit",
        "input_error",
        "unsupported_verifier_message"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "diagnostic_kind": {
      "type": "string",
      "enum": [
        "supported",
        "unsupported_input",
        "unsupported_verifier_message"
      ]
    },
    "help_safety": {
      "type": "string",
      "enum": [
        "repair_hint",
        "triage_only"
      ]
    },
    "span_confidence": {
      "type": "string",
      "enum": [
        "exact_pc",
        "nearest_source_comment",
        "terminal_line_only",
        "none"
      ]
    },
    "message": {
      "type": "string"
    },
    "required_proof": {
      "type": "string"
    },
    "source_span": {
      "$ref": "#/$defs/source_span"
    },
    "related_spans": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/related_span"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "help": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "source_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "line_start",
        "line_end",
        "instruction_pc",
        "source_text"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "line_start": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "line_end": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "instruction_pc": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "source_text": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "related_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "line_start",
        "line_end",
        "instruction_pc",
        "source_text",
        "label"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "line_start": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "line_end": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "instruction_pc": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "source_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "type": "string"
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "detail",
        "line"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "terminal_verifier_error",
            "instruction_pc",
            "verifier_trace",
            "lowering_artifact_signal",
            "verifier_precision_signal"
          ]
        },
        "detail": {
          "type": "string"
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "input_kind",
        "object_path",
        "object_programs",
        "object_analysis_error",
        "trace_state_count",
        "analysis_error"
      ],
      "properties": {
        "case_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "input_kind": {
          "type": "string",
          "enum": [
            "verifier-log",
            "verifier-log-region"
          ]
        },
        "object_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "object_programs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/object_program"
          }
        },
        "object_analysis_error": {
          "type": [
            "string",
            "null"
          ]
        },
        "trace_state_count": {
          "type": "integer",
          "minimum": 0
        },
        "analysis_error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "object_program": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_name",
        "instruction_count",
        "block_count",
        "site_count",
        "verifier_state_site_count",
        "verifier_state_attach_error"
      ],
      "properties": {
        "section_name": {
          "type": "string"
        },
        "instruction_count": {
          "type": "integer",
          "minimum": 0
        },
        "block_count": {
          "type": "integer",
          "minimum": 0
        },
        "site_count": {
          "type": "integer",
          "minimum": 0
        },
        "verifier_state_site_count": {
          "type": "integer",
          "minimum": 0
        },
        "verifier_state_attach_error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
